<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.ui.transcription.TranscriptionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/selected_audio"
            android:textColor="@color/beige"
            android:textStyle="bold"
            android:fontFamily="@font/purple_purse"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/selectedAudioText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/beige"
            tools:text="content://media/external/audio/media/14"
            android:fontFamily="@font/purple_purse"
            android:textSize="18sp"  />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/time_signature_label"
            android:textColor="@color/beige"
            android:fontFamily="@font/purple_purse"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/timeSignatureInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/time_signature_hint"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/beige"
            android:textColorHint="@color/beige"
            android:fontFamily="@font/purple_purse"
            tools:text="4/4" />

        <Button
            android:id="@+id/transcribeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/purple_purse"
            android:text="Transcribe!"
            android:textSize="18sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/beige"
            android:visibility="gone"
            tools:text="Transcribing… 42%" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@android:color/holo_red_dark"
            android:visibility="gone"
            tools:text="Failed to load model from assets/speech_to_text.tflite" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/retry"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
